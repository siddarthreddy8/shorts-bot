# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real secrets.

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenRouter (script generation + scene planning) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- FAL.ai (image + video generation) ---
FAL_API_KEY=
FAL_MODEL=fal-ai/flux/dev                                    # static image fallback
FAL_VIDEO_MODEL=fal-ai/kling-video/v2.1/standard/text-to-video  # AI video clips

# --- YouTube ---
# API key for read-only channel monitoring (Google Cloud Console → Credentials → API Key)
YOUTUBE_API_KEY=
# Path to OAuth client secrets JSON (for uploading — download from Google Cloud Console)
YOUTUBE_OAUTH_CLIENT_SECRETS=./config/youtube_client_secret.json
# Path where the OAuth token is cached after first auth
YOUTUBE_TOKEN_CACHE=./config/youtube_token.json
# Your destination YouTube channel ID (UCxxxxx...) — set after creating the channel
YOUTUBE_DESTINATION_CHANNEL_ID=

# --- TTS ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_HI=

# --- Pipeline ---
PIPELINE_RUN_TIME=09:00
PIPELINE_TIMEZONE=Asia/Kolkata
WHISPER_MODEL=large-v3
TARGET_LANGUAGE_DEFAULT=english
SHORT_MAX_DURATION_SEC=58

# --- Notifications ---
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
