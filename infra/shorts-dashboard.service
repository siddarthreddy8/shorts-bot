[Unit]
Description=Shorts Bot Dashboard (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/shorts-bot
ExecStart=/home/ubuntu/shorts-bot/.venv/bin/uvicorn src.api.main:app \
    --host 0.0.0.0 --port 8000
EnvironmentFile=/home/ubuntu/shorts-bot/.env
Restart=on-failure
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
